name: Build Askey SBE1V1K QWRT Firmware

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04

    steps:
      - name: Free Disk Space (Maximize Ubuntu Runner Storage)
        run: |
          sudo rm -rf /usr/share/dotnet /usr/local/lib/android /opt/ghc /usr/libexec/docker /usr/share/swift /usr/local/share/powershell 2>/dev/null || true
          sudo apt-get remove -y google-chrome-stable microsoft-edge-stable firefox mono-devel mssql-tools azure-cli 2>/dev/null || true
          sudo apt-get autoremove -y 2>/dev/null || true
          sudo apt-get clean
          df -h

      - name: Clean Clone Andrew QSDK Genuine Source Code
        run: |
          mkdir -p /home/runner/qsdk_build
          # 💎【核心正位】精確拉取支援 5.4.213 高通工廠內核的專屬 Askey 原始碼分支
          git clone -b sbe1v1k https://github.com /home/runner/qsdk_build

      - name: Install System Dependencies
        run: |
          sudo apt-get update --fix-missing || true
          sudo apt-get install -y --fix-missing build-essential ccache file flex g++ gawk gcc gettext git libncurses-dev libssl-dev python3-dev rsync swig u-boot-tools unzip wget zstd binutils bzip2 subversion diffutils which bison m4 patch jq ecj fastjar qemu-utils quilt lzma libtool libglib2.0-dev libelf-dev e2fsprogs-extra libattr1-dev libcap-dev libmpc-dev libmpfr-dev libgmp-dev libz-dev pigz libzstd-dev squashfs-tools device-tree-compiler gcc-multilib g++-multilib libc6-dev-i386 lib32readline-dev || true

      - name: Update and Install QWRT Core Feeds
        run: |
          cd /home/runner/qsdk_build
          # 💎【網頁大復活】全面打撈並安裝高通閉源 QSDK 專用的全套 LuCI 中文面板與 uhttpd 組件
          ./scripts/feeds update -a
          ./scripts/feeds install -a

      - name: Configure QWRT Profile (Force Lock QSDK 5.4.213 Core)
        run: |
          cd /home/runner/qsdk_build
          
          # 100% 鎖定高通 QualcommBE 萬兆旗艦晶片組
          echo "CONFIG_TARGET_qualcommbe=y" > .config
          echo "CONFIG_TARGET_qualcommbe_ipq95xx=y" >> .config
          echo "CONFIG_TARGET_qualcommbe_ipq95xx_DEVICE_askey_sbe1v1k=y" >> .config
          
          # 💎【焊死網絡貓與硬體加速】開啟最頂級的 PPE (Packet Process Engine) 與 SFE 雙加速名冊
          echo "CONFIG_PACKAGE_luci=y" >> .config
          echo "CONFIG_PACKAGE_luci-ssl=y" >> .config
          echo "CONFIG_PACKAGE_uhttpd=y" >> .config
          echo "CONFIG_PACKAGE_uhttpd-mod-ubus=y" >> .config
          echo "CONFIG_PACKAGE_kmod-qca-nss-ppe=y" >> .config
          echo "CONFIG_PACKAGE_kmod-qca-nss-sfe=y" >> .config
          
          echo "CONFIG_AUTOREBUILD=y" >> .config
          echo "CONFIG_SIGNATURE_CHECK=n" >> .config
          echo "CONFIG_SIGNED_PACKAGES=n" >> .config
          make defconfig

      - name: Compile QWRT Firmware (Strict Standard Mode)
        run: |
          cd /home/runner/qsdk_build
          export FORCE_UNSAFE_CONFIGURE=1
          # 不使用 -i！保證代碼 100% 健康，只要有錯誤就立即報警
          make -j$(nproc) V=s

      - name: Hard Copy QWRT Finished Binaries
        run: |
          mkdir -p /home/runner/qwrt_output
          cp -v /home/runner/qsdk_build/bin/targets/qualcommbe/ipq95xx/openwrt-qualcommbe-ipq95xx-askey_sbe1v1k-* /home/runner/qwrt_output/ 2>/dev/null || true
          echo "==> Checked Real QWRT Files in Cargo:"
          ls -lh /home/runner/qwrt_output/

      - name: Upload Finished QWRT Firmware Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: Askey_SBE1V1K_QWRT_5.4.213_Firmware
          path: /home/runner/qwrt_output/
