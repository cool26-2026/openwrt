name: Build OpenWrt for Askey SBE1V1K

on:
  workflow_dispatch: # 允許您在網頁上手動點選按鈕觸發編譯

jobs:
  build:
    runs-on: ubuntu-22.04 # 呼叫 GitHub 最健康的 Ubuntu 22.04 雲端虛擬機

    steps:
    - name: Checkout Repository
      uses: actions/checkout@v4

    - name: Install Building Dependencies
      run: |
        sudo apt-get update
        sudo apt-get install -y build-essential ccache file flex g++ gawk gcc gettext git libncurses-dev libssl-dev python3-dev rsync swig u-boot-tools unzip wget zstd

    - name: Clone OpenWrt and Merge Code
      run: |
        git clone https://github.com openwrt
        cd openwrt
        echo "src-git packages https://openwrt.org" > feeds.conf
        echo "src-git luci https://openwrt.org" >> feeds.conf
        ./scripts/feeds update -a
        ./scripts/feeds install -a

    - name: Inject Hardware Configuration
      run: |
        cd openwrt
        echo "CONFIG_TARGET_qualcommbe=y" > .config
        echo "CONFIG_TARGET_qualcommbe_ipq95xx=y" >> .config
        echo "CONFIG_TARGET_qualcommbe_ipq95xx_DEVICE_askey_sbe1v1k=y" >> .config
        echo "CONFIG_PACKAGE_luci=y" >> .config
        make defconfig
        
    - name: Global Replace Tilde For APK Toolchain
      run: |
        cd openwrt
        find ./include ./scripts ./package -type f \( -name "*.mk" -o -name "*.sh" -o -name "Makefile" \) -exec sed -i 's/\~/./g' {} + 2>/dev/null

    - name: Run Multi-Core Compilation
      run: |
        cd openwrt
        export FORCE_UNSAFE_CONFIGURE=1
        make target/linux/install -j$(nproc) V=s

    - name: Collect and Upload Firmware Firmware Artifacts
      uses: actions/upload-artifact@v4
      with:
        name: Askey_SBE1V1K_Firmware
        path: openwrt/bin/targets/qualcommbe/ipq95xx/*
